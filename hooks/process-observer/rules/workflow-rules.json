{
  "version": "1.0",
  "description": "Workflow compliance rules — enforces role boundaries. Logic: extensions NOT in allowed_extensions are treated as code files and blocked from direct Edit/Write.",
  "allowed_extensions": [
    ".md", ".txt", ".rst",
    ".json", ".yaml", ".yml", ".toml", ".ini", ".cfg", ".conf",
    ".xml", ".plist",
    ".css", ".scss", ".less",
    ".html", ".htm",
    ".svg", ".png", ".jpg", ".jpeg", ".gif", ".ico", ".webp",
    ".csv", ".tsv",
    ".gitignore", ".gitattributes",
    ".editorconfig"
  ],
  "rules": [
    {
      "id": "direct-code-edit",
      "tool": "Edit",
      "severity": "critical",
      "reason": "代码变更必须通过 Developer (Codex) 实现，不可直接编辑"
    },
    {
      "id": "direct-code-write",
      "tool": "Write",
      "severity": "critical",
      "reason": "代码文件必须通过 Developer (Codex) 创建，不可直接写入"
    },
    {
      "id": "codex-unstructured-prompt",
      "tool": "mcp__codex-reviewer__codex",
      "severity": "high",
      "reason": "调用 Developer 必须使用结构化 prompt（需包含 ## 标题）"
    }
  ]
}
